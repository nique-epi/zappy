#!/bin/sh
# Enforce Conventional Commits on the commit message.
# No external tooling: pure POSIX shell + grep.
# Activated via `git config core.hooksPath .githooks` (done by CMake configure).

msg_file="$1"

subject=$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)

case "$subject" in
  "Merge "* | "Revert "* | "fixup!"* | "squash!"* | "Revert \""*)
    exit 0
    ;;
esac

types="build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test"
pattern="^(${types})(\([a-z0-9._/-]+\))?!?: ?[a-z].*"

if ! printf '%s' "$subject" | grep -Eq "$pattern"; then
  echo "  Commit refusé : message non conforme aux Conventional Commits."
  echo ""
  echo "  Reçu   : $subject"
  echo ""
  echo "  Format : <type>(<scope optionnel>):<description>"
  echo "  - espace après ':' optionnel"
  echo "  - la description DOIT commencer par une minuscule (a-z)"
  echo "  Exemple: feat(server): add gui protocol parser"
  echo ""
  echo "  Types autorisés :"
  echo "    build chore ci docs feat fix perf refactor revert style test"
  exit 1
fi

header_length=$(printf '%s' "$subject" | wc -c | tr -d ' ')
if [ "$header_length" -gt 100 ]; then
  echo "Commit refusé : sujet trop long (${header_length} > 100 caractères)."
  exit 1
fi

body=$(grep -v '^#' "$msg_file")

if printf '%s\n' "$body" | grep -Eiq '^[[:space:]]*co-authored-by:'; then
  echo "Commit refusé : trailer 'Co-Authored-By:' interdit."
  echo "Aucun co-auteur n'est autorisé dans les messages de commit."
  exit 1
fi

if printf '%s\n' "$body" \
    | grep -Eiq 'generated with|claude\.com/claude-code|noreply@anthropic\.com'; then
  echo "Commit refusé : mention d'assistant IA interdite."
  exit 1
fi

if printf '%s\n' "$body" | grep -Fq '🤖'; then
  echo "Commit refusé : emoji robot interdit dans le message."
  exit 1
fi

exit 0
